/* HeroSection.css */

.body {

  background-color: yellow;
  ;
}


/* General styling */
.hero-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 50px;
  /* Adjust as needed */
}

.content-column {
  flex: 1;
  max-width: 50%;
}

.image-column {
  flex: 1;
  max-width: 50%;
}

/* Heading styles */
h1 {
  font-size: 2.5em;
  /* Adjust as needed */
  line-height: 1.2;
  margin-bottom: 20px;
  /* Adjust as needed */
  font-family: 'Your Font', sans-serif;
  /* Specify your custom font */
}

.highlight {
  color: #ff0000;
  /* Adjust the color as needed */
  font-weight: 100;
  font-size: 44px;
}

/* Paragraph styles */
p {
  font-size: 1.2em;
  /* Adjust as needed */
  line-height: 1.5;
  margin-bottom: 30px;
  /* Adjust as needed */
  color: #555;
  /* Adjust the color as needed */
}

/* Social icons styles */
.social-icons {
  display: flex;
  gap: 10px;
}

.social-icons img {
  width: 30px;
  /* Adjust as needed */
  height: 30px;
  /* Adjust as needed */

}

/* Image styles */
.image-column img {
  width: 100%;
  height: auto;
  border-radius: 8px;
  /* Optional: Add rounded corners to the image */
}

/* Responsive styles for mobile */
@media (max-width: 768px) {
  .hero-section {
    flex-direction: column;
    /* Stack columns on top of each other */
    padding: 20px;
    /* Adjust as needed */
  }

  .content-column,
  .image-column {
    max-width: 100%;
    /* Take up the full width on mobile */
  }

  h1 {
    font-size: 2em;
    /* Adjust as needed for mobile */
    text-align: center;
    margin-bottom: 15px;
    /* Adjust as needed */
  }

  p {
    text-align: center;
  }
}

.bold {
  font-weight: 900;
}