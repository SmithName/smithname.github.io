/* Skills.css */

.SkillsContainer {
    margin: 55px;
    font-family: 'Arial', sans-serif;
}

.bold {
    font-weight: bold;
}

.SkillsList {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 45px;
}

.SkillsList img {
    width: 85%;
    height: auto;
    ;
}

@media (max-width: 768px) {
    .SkillsList {
        grid-template-columns: repeat(2, 1fr);
    }
}

h2 {
    text-align: center;
}