/* Experience.css */

.ExperienceContainer {
    margin: 20px;
    font-family: 'Arial', sans-serif;
}

.bold {
    font-weight: bold;
}

.ExperienceList {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.ExperienceItem {
    display: flex;
    flex-direction: column;
}

.DateRange {
    color: #555;
    margin-bottom: 10px;
}

.ExperienceItem img {
    width: 50px;
    /* Adjust the size as needed */
    height: 50px;
    /* Adjust the size as needed */
    margin-right: 10px;
}